@model IEnumerable<temp.Models.SensorData>

@{
    ViewData["Title"] = "IoT Dashboard";
}

<style>

    body {
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(rgba(10,15,25,0.82), rgba(10,15,25,0.90)), url('https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=2070&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        color: white;
        overflow-x: hidden;
    }

    .main-container {
        max-width: 1350px;
        margin: auto;
        padding: 40px 25px;
    }

    /* HERO */

    .hero {
        text-align: center;
        padding: 55px;
        border-radius: 35px;
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 10px 35px rgba(0,0,0,0.35);
        margin-bottom: 40px;
    }

        .hero h1 {
            font-size: 70px;
            margin-bottom: 10px;
            font-weight: 800;
            letter-spacing: 2px;
            color: #38bdf8;
        }

        .hero p {
            font-size: 22px;
            color: #cbd5e1;
            line-height: 1.7;
        }

    /* TOP CARDS */

    .top-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
        margin-bottom: 35px;
    }

    .info-card {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(14px);
        border-radius: 28px;
        padding: 30px;
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 8px 25px rgba(0,0,0,0.25);
        transition: 0.3s ease;
    }

        .info-card:hover {
            transform: translateY(-5px);
            background: rgba(255,255,255,0.11);
        }

    .info-title {
        font-size: 18px;
        color: #94a3b8;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .info-value {
        font-size: 38px;
        font-weight: bold;
        color: white;
    }

    /* TABLE CARD */

    .sensor-card {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(16px);
        border-radius: 30px;
        padding: 30px;
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 10px 35px rgba(0,0,0,0.35);
    }

    table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
    }

    thead {
        background: rgba(56,189,248,0.18);
    }

        thead th {
            padding: 22px;
            text-align: center;
            color: #38bdf8;
            font-size: 18px;
            font-weight: 700;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

    tbody tr {
        transition: 0.25s ease;
    }

        tbody tr:hover {
            background: rgba(255,255,255,0.05);
            transform: scale(1.01);
        }

    tbody td {
        padding: 20px;
        text-align: center;
        font-size: 17px;
        color: #e2e8f0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .device {
        font-weight: 700;
        color: #38bdf8;
        font-size: 18px;
    }

    .temp {
        font-size: 24px;
        font-weight: bold;
        color: #f87171;
    }

    .footer {
        text-align: center;
        margin-top: 35px;
        color: #94a3b8;
        font-size: 18px;
    }

    .empty-box {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(16px);
        border-radius: 30px;
        padding: 60px;
        text-align: center;
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 10px 35px rgba(0,0,0,0.35);
    }

        .empty-box h2 {
            color: #38bdf8;
            font-size: 42px;
        }

        .empty-box p {
            color: #cbd5e1;
            font-size: 20px;
        }

</style>

<div class="main-container">

    <div class="hero">

        <h1>IoT Dashboard</h1>

        <p>
            Real-time monitoring system for sensor data received from the device.
        </p>

    </div>

    @if (Model != null && Model.Any())
    {
        var latest = Model.First();

        <div class="top-cards">

            <div class="info-card">

                <div class="info-title">
                    Device
                </div>

                <div class="info-value">
                    @latest.DeviceId
                </div>

            </div>

            <div class="info-card">

                <div class="info-title">
                    Current Temperature
                </div>

                <div class="info-value">
                    @latest.Temperature.ToString("0.0") °C
                </div>

            </div>

            <div class="info-card">

                <div class="info-title">
                    Last Update
                </div>

                <div style="font-size:20px; font-weight:600;">
                    @latest.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
                </div>

            </div>

        </div>

        <div class="sensor-card">

            <table>

                <thead>
                    <tr>
                        <th>Device</th>
                        <th>Temperature</th>
                        <th>Date & Time</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td class="device">
                                @item.DeviceId
                            </td>

                            <td class="temp">
                                @item.Temperature.ToString("0.0") °C
                            </td>

                            <td>
                                @item.Timestamp.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

        <div class="footer">
            Smart Monitoring • Live Data • Embedded Systems
        </div>
    }
    else
    {
        <div class="empty-box">

            <h2>No sensor data available</h2>

            <p>
                Waiting for incoming data from the IoT device.
            </p>

        </div>
    }

</div>

<script>
    setInterval(() => {
        location.reload();
    }, 2000);
</script>